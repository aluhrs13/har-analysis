<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HAR Analysis - Bundle Composition</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
        margin: 0;
        padding: 20px;
        color: #333;
        background-color: #f8f9fa;
      }
      .container {
        max-width: 1400px;
        margin: 0 auto;
      }
      h1 {
        text-align: center;
        margin-bottom: 6px;
        color: #2c3e50;
      }
      .subtitle {
        text-align: center;
        color: #6c757d;
        margin-bottom: 20px;
      }
      .nav {
        text-align: center;
        margin-bottom: 20px;
      }
      .nav a {
        margin: 0 10px;
        color: #0066cc;
        text-decoration: none;
        font-weight: 500;
      }
      .card {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 24px;
      }
      h2 {
        color: #2c3e50;
        margin-top: 0;
      }
      .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 16px;
      }
      .legend-item {
        display: flex;
        align-items: center;
        font-size: 14px;
      }
      .swatch {
        width: 14px;
        height: 14px;
        border-radius: 3px;
        margin-right: 6px;
        display: inline-block;
      }
      #treemap {
        position: relative;
        width: 100%;
        height: 560px;
        background: #f1f3f5;
        border-radius: 4px;
        overflow: hidden;
      }
      .cell {
        position: absolute;
        box-sizing: border-box;
        border: 1px solid rgba(255, 255, 255, 0.7);
        overflow: hidden;
        color: #1a1a1a;
        text-decoration: none;
        font-size: 11px;
        line-height: 1.2;
        padding: 3px 4px;
        transition: outline 0.1s;
      }
      .cell:hover {
        outline: 2px solid #2c3e50;
        z-index: 5;
      }
      .cell .cell-label {
        font-weight: 600;
        word-break: break-all;
      }
      .cell .cell-size {
        opacity: 0.8;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      th,
      td {
        padding: 8px 12px;
        text-align: left;
        border-bottom: 1px solid #e9ecef;
      }
      th {
        background-color: #f8f9fa;
      }
      td.num,
      th.num {
        text-align: right;
      }
      .bar-row {
        margin-bottom: 14px;
      }
      .bar-head {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-bottom: 4px;
      }
      .bar-url {
        max-width: 70%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .bar-url a {
        color: #0066cc;
        text-decoration: none;
      }
      .bar {
        display: flex;
        height: 22px;
        border-radius: 4px;
        overflow: hidden;
        background: #e9ecef;
      }
      .seg {
        height: 100%;
      }
      .seg-code {
        background: #4c6ef5;
      }
      .seg-strings {
        background: #f59f00;
      }
      .seg-images {
        background: #15aabf;
      }
      .warn {
        color: #b02a37;
        font-size: 12px;
        margin-left: 6px;
      }
      .muted {
        color: #868e96;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Bundle Composition</h1>
      <div class="subtitle">
        Total decoded body weight:
        <strong id="total-weight"></strong>
        across {{ composition.items | length }} responses with bodies
      </div>
      <div class="nav">
        <a href="/">&larr; Dashboard</a>
        <a href="/gallery">Image Gallery</a>
        <a href="/duplicates">Duplicates</a>
      </div>

      <div class="card">
        <h2>Page weight by file type</h2>
        <div class="legend">
          {% for c in composition.categories %}
          <div class="legend-item">
            <span class="swatch" style="background: {{ c.color }}"></span>
            {{ c.name }} ({{ c.count }})
          </div>
          {% endfor %}
        </div>
        <div id="treemap"></div>
        <p class="muted" style="font-size: 12px; margin-bottom: 0">
          Each cell is one response, sized by decoded bytes. Click to open its
          detail page. Responses without captured bodies are excluded.
        </p>
      </div>

      <div class="card">
        <h2>Category summary</h2>
        <table>
          <thead>
            <tr>
              <th>Category</th>
              <th class="num">Responses</th>
              <th class="num">Size (KB)</th>
              <th class="num">% of weight</th>
            </tr>
          </thead>
          <tbody>
            {% for c in composition.categories %}
            <tr>
              <td>
                <span class="swatch" style="background: {{ c.color }}"></span>
                {{ c.name }}
              </td>
              <td class="num">{{ c.count }}</td>
              <td class="num">{{ (c.bytes / 1024) | round(1) }}</td>
              <td class="num">{{ c.pct | round(1) }}%</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="card">
        <h2>Inside each JavaScript bundle</h2>
        <div class="legend">
          <div class="legend-item">
            <span class="swatch seg-code"></span> Code
          </div>
          <div class="legend-item">
            <span class="swatch seg-strings"></span> Strings
          </div>
          <div class="legend-item">
            <span class="swatch seg-images"></span> Embedded images
          </div>
        </div>
        {% for b in composition.bundles %}
        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-url">
              <a href="/pages/{{ b.id }}" title="{{ b.url }}">{{ b.url }}</a>
              {% if not b.analyzed %}
              <span class="muted">(not parsed)</span>
              {% endif %}
              {% if b.mismatch > 0 %}
              <span class="warn"
                >analysis exceeds size by
                {{ (b.mismatch / 1024) | round(1) }} KB</span
              >
              {% endif %}
            </span>
            <span class="muted">{{ (b.total / 1024) | round(1) }} KB</span>
          </div>
          <div class="bar" title="Code {{ b.codePct | round(0) }}% · Strings {{ b.stringsPct | round(0) }}% · Images {{ b.imagesPct | round(0) }}%">
            <div class="seg seg-code" style="width: {{ b.codePct }}%"></div>
            <div class="seg seg-strings" style="width: {{ b.stringsPct }}%"></div>
            <div class="seg seg-images" style="width: {{ b.imagesPct }}%"></div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    <script>
      const items = {{ composition.items | dump | safe }};
      const totalBytes = {{ composition.totalBytes }};

      function fmtBytes(n) {
        if (n >= 1024 * 1024) return (n / (1024 * 1024)).toFixed(2) + " MB";
        if (n >= 1024) return (n / 1024).toFixed(1) + " KB";
        return n + " B";
      }
      document.getElementById("total-weight").textContent = fmtBytes(totalBytes);

      // Squarified treemap (Bruls et al.), dependency-free.
      function squarify(data, x0, y0, width, height) {
        const out = [];
        const total = data.reduce((a, b) => a + b.value, 0);
        if (total <= 0 || width <= 0 || height <= 0) return out;
        const scale = (width * height) / total;
        const nodes = data.map((d) => ({ it: d, area: d.value * scale }));
        let rect = { x: x0, y: y0, w: width, h: height };
        let i = 0;

        function worst(row) {
          const sum = row.reduce((a, b) => a + b.area, 0);
          let max = -Infinity,
            min = Infinity;
          for (const r of row) {
            if (r.area > max) max = r.area;
            if (r.area < min) min = r.area;
          }
          const side = Math.min(rect.w, rect.h);
          const s2 = sum * sum,
            side2 = side * side;
          if (s2 === 0) return Infinity;
          return Math.max((side2 * max) / s2, s2 / (side2 * min));
        }

        function place(row) {
          const rowArea = row.reduce((a, b) => a + b.area, 0);
          if (rect.w >= rect.h) {
            const rowW = rowArea / rect.h;
            let y = rect.y;
            for (const r of row) {
              const cellH = rowW ? r.area / rowW : 0;
              out.push({ it: r.it, x: rect.x, y: y, w: rowW, h: cellH });
              y += cellH;
            }
            rect = { x: rect.x + rowW, y: rect.y, w: rect.w - rowW, h: rect.h };
          } else {
            const rowH = rowArea / rect.w;
            let x = rect.x;
            for (const r of row) {
              const cellW = rowH ? r.area / rowH : 0;
              out.push({ it: r.it, x: x, y: rect.y, w: cellW, h: rowH });
              x += cellW;
            }
            rect = { x: rect.x, y: rect.y + rowH, w: rect.w, h: rect.h - rowH };
          }
        }

        while (i < nodes.length) {
          let row = [nodes[i]];
          let j = i + 1;
          while (j < nodes.length) {
            const next = row.concat(nodes[j]);
            if (worst(next) > worst(row)) break;
            row = next;
            j++;
          }
          place(row);
          i = j;
        }
        return out;
      }

      function renderTreemap() {
        const container = document.getElementById("treemap");
        container.innerHTML = "";
        const w = container.clientWidth;
        const h = container.clientHeight;
        const cells = squarify(
          items.map((it) => ({ value: it.bytes, ref: it })),
          0,
          0,
          w,
          h
        );
        for (const c of cells) {
          const it = c.it.ref;
          const a = document.createElement("a");
          a.className = "cell";
          a.href = "/pages/" + it.id;
          a.style.left = c.x + "px";
          a.style.top = c.y + "px";
          a.style.width = c.w + "px";
          a.style.height = c.h + "px";
          a.style.background = it.color;
          a.title = it.url + "\n" + it.category + " · " + fmtBytes(it.bytes);
          if (c.w > 55 && c.h > 24) {
            let name;
            try {
              const u = new URL(it.url);
              name = u.pathname.split("/").pop() || u.hostname;
            } catch (e) {
              name = it.url;
            }
            a.innerHTML =
              '<div class="cell-label">' +
              name +
              '</div><div class="cell-size">' +
              fmtBytes(it.bytes) +
              "</div>";
          }
          container.appendChild(a);
        }
      }

      renderTreemap();
      let resizeTimer;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(renderTreemap, 150);
      });
    </script>
  </body>
</html>
